# --- DATABASE CONFIG ---
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_PORT=5432

# --- AUTH CONFIG ---
# Generate a random 32+ character string for JWT_SECRET
JWT_SECRET=replace_with_random_jwt_secret
SITE_URL=http://your_vps_ip_address:8000

# --- KEYS ---
# These are used by Storage and other services. 
# In a self-hosted setup, you can generate these or use placeholders for development.
ANON_KEY=replace_with_random_anon_key
SERVICE_ROLE_KEY=replace_with_random_service_role_key

# --- DASHBOARD (Optional) ---
# If you want to run the Supabase Studio dashboard, we can add it later.
